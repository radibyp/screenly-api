# IDLIX API Environment Configuration
# Copy this file to .env and fill in your values

# ── Upstream site ──────────────────────────────────────────────────────────────
# Base URL of the IDLIX site (no trailing slash)
IDLIX_BASE_URL=https://z2.idlixku.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── External request / rendering service ───────────────────────────────────────
# Base URL of the external microservice that performs browser-like rendering and
# fingerprinted requests on the API's behalf. The API process no longer runs a
# browser internally; rendering work is delegated to this service.
REQUEST_SERVICE_URL=http://localhost:8191

# Per-request timeout (ms) when calling the external request service.
REQUEST_SERVICE_TIMEOUT_MS=60000

# ── Cache TTLs (in hours) ──────────────────────────────────────────────────────
CACHE_TTL_PAGE=1
CACHE_TTL_FEATURED=1
CACHE_TTL_CINEMAXXI=1
CACHE_TTL_TRENDING=1
CACHE_TTL_SERIES=1
CACHE_TTL_MCU=1
CACHE_TTL_HOME=1
CACHE_TTL_DETAIL=2
CACHE_TTL_SEARCH=0.5
CACHE_TTL_LEADERBOARD=1
# Stream URLs expire quickly — keep short (0.25h = 15 minutes)
CACHE_TTL_STREAM=0.25
