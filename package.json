    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@scalar/express-api-reference": "^0.10.5",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
